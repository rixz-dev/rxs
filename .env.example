# ANERS Aria c11 — Environment Variables
# Copy file ini ke .env.local dan isi semua value
# JANGAN commit .env.local ke GitHub

# ─── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ─── Upstash Redis ────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── NVIDIA Build API ─────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxx
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# ─── Vercel Blob ──────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx

# ─── Telegram Bot ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=xxxxxx:xxxx
TELEGRAM_ADMIN_CHAT_ID=8294322624

# ─── Admin Panel ─────────────────────────────────────────────────
# SHA-256 hash dari password admin kamu
# Generate: echo -n "passwordmu" | sha256sum
ADMIN_PASSWORD_HASH=bc82f7741ed40ed4d0b2f66b0154eb7402713c34de0ca1dc984e938200dbf198

# Internal API key — string random panjang
INTERNAL_API_KEY=ganti-dengan-random-string-64-chars

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
